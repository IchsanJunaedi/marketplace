# Copy to .env and fill in real values. Never commit .env.

# Database (TiDB Cloud — MySQL-compatible). For TiDB Cloud Serverless add
# ?sslaccept=strict to enforce TLS.
DATABASE_URL="mysql://USER:PASSWORD@HOST:4000/marketplace_d2c?sslaccept=strict"

# Auth.js v5 (NextAuth) — generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# OAuth Providers (Google)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Midtrans Snap (Payment Gateway) — Sandbox by default
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"

# RajaOngkir (Shipping)
RAJAONGKIR_API_KEY=""
